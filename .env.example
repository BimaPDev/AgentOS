# Hermes connector — SSH connection to the Hermes Agent LXC container on Proxmox.
# Defaults in src/lib/connectors/hermes-connector.ts already match the homelab
# setup (container 102, user "hermes"); only override if that changes.
HERMES_SSH_HOST=192.168.50.86
HERMES_SSH_PORT=22
HERMES_SSH_USER=hermes
HERMES_SSH_KEY_PATH=./secrets/agentos_hermes_ed25519
HERMES_BIN_PATH=/home/hermes/.hermes/hermes-agent/venv/bin/hermes
