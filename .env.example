# Hermes connector — SSH connection to the Hermes Agent LXC container on Proxmox.
# Defaults in src/lib/connectors/hermes-connector.ts already match the homelab
# setup (container 102, user "hermes"); only override if that changes.
HERMES_SSH_HOST=192.168.50.86
HERMES_SSH_PORT=22
HERMES_SSH_USER=hermes
HERMES_SSH_KEY_PATH=./secrets/agentos_hermes_ed25519
HERMES_BIN_PATH=/home/hermes/.hermes/hermes-agent/venv/bin/hermes

# 9Router connector — self-hosted AI router (https://9router.com) running
# alongside Hermes on the same container, OpenAI-compatible HTTP API.
# The API key is required for any non-loopback access (9Router's own
# security rule) — get it from the 9Router dashboard's "Endpoint & Key" page.
# Put the real value in .env.local (gitignored), not here.
ROUTER9_HOST=192.168.50.86
ROUTER9_PORT=20128
ROUTER9_API_KEY=
ROUTER9_DEFAULT_MODEL=oc/big-pickle
